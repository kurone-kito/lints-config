{
  "name": "@kurone-kito/lints-config",
  "version": "0.20.0",
  "private": true,
  "description": "My configuration for the Biome / CSpell / lint-staged and other tools",
  "keywords": [
    "biome",
    "config",
    "cspell",
    "lint-staged",
    "markdownlint"
  ],
  "homepage": "https://github.com/kurone-kito/lints-config#readme",
  "bugs": "https://github.com/kurone-kito/lints-config/issues",
  "repository": "github:kurone-kito/lints-config",
  "license": "MIT",
  "author": "kurone-kito <krone@kit.black> (https://kit.black/)",
  "type": "module",
  "files": [],
  "workspaces": {
    "packages": [
      "./packages/*"
    ]
  },
  "scripts": {
    "build": "pnpm run --workspace-concurrency=0 -r build",
    "clean": "pnpm run --no-bail \"/^clean:.+/\"",
    "clean:root": "rimraf -g \"*.tgz\" \"*.tsbuildinfo\" node_modules/.cache",
    "clean:sub": "pnpm run --parallel --workspace-concurrency=0 -r clean",
    "is:prerelease": "scripts/isPrerelease.mjs $(npm pkg get version) pre",
    "is:release": "scripts/isPrerelease.mjs $(npm pkg get version)",
    "echo": "node -e \"console.log(process.argv)\"",
    "lint": "pnpm run \"/lint:.+:check/\"",
    "lint:biome:check": "biome check",
    "lint:biome:fix": "biome check --write",
    "lint:cspell:check": "cspell lint --no-progress --show-suggestions -u \"./**/*\"",
    "lint:fix": "pnpm run \"/lint:.+:fix/\"",
    "lint:markdown:check": "markdownlint-cli2 \"**/*.md\"",
    "lint:markdown:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "postlint:fix": "pnpm run lint:cspell:check",
    "prepare": "husky",
    "publish": "pnpm -r publish",
    "publish:next": "pnpm -r publish --tag next",
    "test": "pnpm run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@cspell/cspell-types": "^9.2.1",
    "@kurone-kito/biome-config": "workspace:^",
    "@kurone-kito/commitlint-config": "workspace:^",
    "@kurone-kito/cspell-config": "workspace:^",
    "@kurone-kito/lint-staged-config": "workspace:^",
    "@kurone-kito/markdownlint-config": "workspace:^",
    "@types/semver": "^7.7.1",
    "cspell": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "markdownlint-cli2": "^0.18.1",
    "rimraf": "^6.0.1",
    "semver": "^7.7.2",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a",
  "engines": {
    "node": "^20.11 || ^22 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
